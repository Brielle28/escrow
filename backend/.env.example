# Copy to `.env.local` (gitignored). Never commit real keys to Git.

# OffCKB proxy from `offckb node` (often 28114).
CKB_RPC_URL=http://127.0.0.1:28114

# From `offckb accounts` — row you chose (e.g. 0).
OFFCKB_ACCOUNT_INDEX=0

# Same row: CKB address (ckt1...) and private key (0x...) — LOCAL DEVNET ONLY.
DEPLOYER_ADDRESS=
DEPLOYER_PRIVATE_KEY=

# From same `offckb accounts` row (script / pubkey — useful for txs & debugging).
DEPLOYER_PUBKEY=
DEPLOYER_LOCK_ARG=

# Lock script for this account (often secp256k1 single-sig). From `offckb accounts` → lockScript.
DEPLOYER_LOCK_CODE_HASH=
DEPLOYER_LOCK_HASH_TYPE=
DEPLOYER_LOCK_SCRIPT_ARGS=

# Integration runner (optional)
# INTEGRATION_SPEND_MODE=release
# INTEGRATION_PARTY_SEED=escrow-phase-d-devnet
# INTEGRATION_MIN_SINCE=0
# INTEGRATION_ESCROW_CAPACITY=150000000000
