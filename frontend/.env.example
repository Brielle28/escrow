# Optional: default CCC client when app loads (see src/providers/CccProvider.tsx)
# VITE_CKB_NETWORK=testnet
# VITE_CKB_NETWORK=mainnet

# Auth API: leave unset for local dev — the Vite dev server proxies /api → http://127.0.0.1:8787 (run `pnpm --filter escrow-backend dev`).
# Set only if your API is on another host:
# VITE_API_BASE_URL=https://api.example.com
