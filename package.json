{
  "name": "escrow",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "build:contracts": "pnpm --filter js-vm run build",
    "devnet:node": "offckb node",
    "deploy:devnet": "offckb deploy --network devnet -y --target ./contracts/on-chain-script/dist/index.bc --output ./deployment",
    "system-scripts:devnet": "offckb system-scripts --export-style ccc -o ./deployment/system-scripts.devnet.json",
    "prep:devnet": "pnpm run build:contracts && pnpm run deploy:devnet && pnpm run system-scripts:devnet",
    "test": "pnpm --filter js-vm-tests run test",
    "test:integration": "pnpm --filter escrow-backend run integration:devnet",
    "typecheck": "pnpm -r --if-present run typecheck",
    "dev": "pnpm --filter escrow-web dev",
    "lint": "pnpm -r run lint --if-present",
    "setup:tools": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-tools.ps1"
  },
  "devDependencies": {
    "prettier": "~3.5.3",
    "prettier-plugin-organize-imports": "~4.1.0",
    "rimraf": "~6.0.1",
    "typescript": "~5.8.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
